def compute_health_score(
    df: pd.DataFrame,
    engagement_col: str = "engagement_score",
    pipeline_col: str = "total_pipeline_value",
    winrate_col: str = "win_rate",
    recency_col: str = "days_since_last_activity",
) -> pd.Series:
    """
    Compute a composite health score (0–100) for each account.

    Weighted combination:
        40% engagement + 30% pipeline + 20% win rate + 10% recency
    """
    from sklearn.preprocessing import MinMaxScaler

    scaler = MinMaxScaler()
    cols = [engagement_col, pipeline_col, winrate_col, recency_col]
    available = [c for c in cols if c in df.columns]
    scaled = pd.DataFrame(
        scaler.fit_transform(df[available]),
        columns=available,
        index=df.index,
    )

    # Invert recency (lower days = better)
    if recency_col in scaled.columns:
        scaled[recency_col] = 1 - scaled[recency_col]

    weights = {
        engagement_col: 0.40,
        pipeline_col: 0.30,
        winrate_col: 0.20,
        recency_col: 0.10,
    }

    score = sum(
        scaled[col] * weights.get(col, 0.25)
        for col in available
    )
    return (score * 100).round(1)

# Segment Profiling
# ──────────────────────────────────────────────

def profile_segments(
    df: pd.DataFrame,
    segment_col: str = "segment_name",
    profile_cols: list = None,
) -> pd.DataFrame:
    """
    Generate descriptive statistics per segment.

    Parameters
    ----------
    df : pd.DataFrame
        Segmented DataFrame.
    segment_col : str
        Column with segment names.
    profile_cols : list
        Features to profile. Uses defaults if None.

    Returns
    -------
    pd.DataFrame
        Segment-level summary statistics.
    """
    if profile_cols is None:
        profile_cols = [
            "annual_revenue_usd", "employee_count",
            "total_opportunities", "total_pipeline_value",
            "win_rate", "engagement_score", "avg_lead_score",
            "days_since_last_activity",
        ]

    available = [c for c in profile_cols if c in df.columns]

    profile = df.groupby(segment_col)[available].agg(["mean", "median", "count"])
    return profile



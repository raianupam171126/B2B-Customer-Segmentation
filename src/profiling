"""
Segment Profiling Module
========================
Assigns business-meaningful names to clusters, generates segment profiles,
and produces actionable recommendations per segment.
"""

import numpy as np
import pandas as pd


# ──────────────────────────────────────────────
# Segment Naming
# ──────────────────────────────────────────────

DEFAULT_SEGMENT_NAMES = {
    0: "🏆 Tier 1 — Strategic Champions",
    1: "🌟 Tier 2 — Growth Accounts",
    2: "🔄 Tier 3 — Nurture Pipeline",
    3: "⚠️ Tier 4 — At-Risk / Dormant",
    4: "🌱 Tier 5 — New / Emerging",
}


def assign_segment_names(
    df: pd.DataFrame,
    cluster_col: str = "kmeans_cluster",
    score_col: str = "health_score",
    names: dict = None,
) -> pd.DataFrame:
    """
    Assign business-meaningful names to clusters, ranked by a score.

    Parameters
    ----------
    df : pd.DataFrame
        DataFrame with cluster labels.
    cluster_col : str
        Column containing cluster IDs.
    score_col : str
        Column to rank clusters by (highest = best tier).
    names : dict, optional
        Mapping of rank → name. Uses defaults if None.

    Returns
    -------
    pd.DataFrame
        DataFrame with 'segment_name' column added.
    """
    if names is None:
        names = DEFAULT_SEGMENT_NAMES

    # Rank clusters by mean score
    cluster_ranks = (
        df.groupby(cluster_col)[score_col]
        .mean()
        .sort_values(ascending=False)
        .index.tolist()
    )

    rank_map = {}
    for rank, cluster_id in enumerate(cluster_ranks):
        rank_map[cluster_id] = names.get(rank, f"Segment {rank + 1}")

    df = df.copy()
    df["segment_name"] = df[cluster_col].map(rank_map)
    return df


